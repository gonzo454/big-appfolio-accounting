# AppFolio Reports API
APPFOLIO_CLIENT_ID=your-client-id
APPFOLIO_CLIENT_SECRET=your-client-secret
APPFOLIO_DATABASE=your-subdomain

# Email delivery (use Gmail App Password or any SMTP)
# For Gmail: generate an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# Report recipient
REPORT_EMAIL=mike@metify.io
